# Plaid sandbox credentials
# Get these from https://dashboard.plaid.com/developers/keys (sandbox only)
PLAID_CLIENT_ID=
PLAID_SECRET_SANDBOX=
PLAID_ENV=sandbox
PLAID_PRODUCTS=transactions,auth
PLAID_COUNTRY_CODES=US

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-7-sonnet-20250219

# Backend
API_HOST=127.0.0.1
API_PORT=8000

# Cloud SQL portfolio-pg / aifp database
# Local development via Cloud SQL Auth Proxy (run scripts/db-proxy.sh first):
DATABASE_URL=postgresql+asyncpg://postgres:CHANGEME@127.0.0.1:5432/aifp
# Pull the password from Secret Manager:
#   gcloud secrets versions access latest --secret=portfolio-pg-postgres-password --project=osmoti-auth
# In production (Cloud Run), set DATABASE_URL via the Secret Manager binding instead.

# Frontend -> Backend
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
